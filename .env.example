# Authentication
# ---------------
# claude-design-mcp routes every model call through the local `claude` CLI
# (Claude Code), inheriting whatever OAuth login that CLI is using. There is
# NO API key needed; ANTHROPIC_API_KEY / ANTHROPIC_AUTH_TOKEN /
# CLAUDE_CODE_USE_BEDROCK / CLAUDE_CODE_USE_VERTEX are scrubbed from the
# subprocess env so OAuth wins. To authorize:
#
#   1. Install Claude Code: https://docs.claude.com/en/docs/claude-code/
#   2. Run `claude login` and complete the OAuth flow
#   3. Verify with `claude --version` and `claude-design-mcp --check`
#
# Power-user opt-out (use API key / Bedrock / Vertex instead of OAuth):
#   CLAUDE_DESIGN_ALLOW_API_KEY=1

# Optional: model selection. Defaults shown.
# Use Sonnet for fast iteration, Opus for the most ambitious designs.
CLAUDE_DESIGN_MODEL=claude-sonnet-4-6
CLAUDE_DESIGN_MODEL_OPUS=claude-opus-4-7

# Optional: where designs are stored. Defaults to ./studio next to the package.
CLAUDE_DESIGN_STUDIO_DIR=

# Optional: force a specific logged-in Claude Code CLI. By default the server
# prefers `claude` / `claude.exe` on PATH before falling back to SDK behavior.
CLAUDE_DESIGN_CLI_PATH=

# Optional: render screenshots automatically when designs are created (requires playwright).
# Set to "1" or "true" to enable. Default is auto-detect.
CLAUDE_DESIGN_AUTO_RENDER=auto

# Optional: render runtime paths. Useful on Windows hosts where the default
# user temp dir is locked down, or when browser payloads are installed locally.
CLAUDE_DESIGN_PLAYWRIGHT_TMP=
CLAUDE_DESIGN_PLAYWRIGHT_BROWSERS_PATH=

# Optional: Chromium sandbox policy for screenshots: auto, 1/true, or 0/false.
# auto tries sandboxed first and falls back only if this host cannot open pages.
CLAUDE_DESIGN_CHROMIUM_SANDBOX=auto

# Optional: viewport defaults for screenshots (width x height).
CLAUDE_DESIGN_VIEWPORT=1440x900

# Optional: preserve auth-override env vars instead of scrubbing them.
# Set to 1 if you intentionally want to use ANTHROPIC_API_KEY, Bedrock, or
# Vertex. Default is 0 (scrub, force OAuth).
CLAUDE_DESIGN_ALLOW_API_KEY=0
